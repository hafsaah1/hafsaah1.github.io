---
import Notebook from '../layouts/Notebook.astro';
import { SITE } from '../config';
---
<Notebook title="welcome to my site">
  <p>hi, i'm <strong>{SITE.name}</strong> — this is my corner of the web, built like
     a digital planner. i mostly build things at the intersection of robotics,
     machine learning, and embedded systems.</p>
  <br />
  <p>this theme is inspired by my love of the
     <a href="https://www.1101.com/store/techo/en/">Hobonichi Techo</a> planner.
     flip through the days on the left to get around →
     check out my <a href="/projects">projects</a>, read the
     <a href="/blog">blog</a>, or sign the <a href="/guestbook">guestbook</a>.</p>
  <br />
  <h2>latest project</h2>
  <p><a href="/projects/langpick"><strong>LangPick</strong></a> — type
     "put the red block on the blue plate" and watch a Franka arm do it.
     CLIP grounds the language, scripted IK does the motion. built in MuJoCo.</p>
  <br />
  <p style="opacity:.7">Powered by: Astro · Created by: {SITE.name}</p>
</Notebook>
