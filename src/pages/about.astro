---
import Notebook from '../layouts/Notebook.astro';
import { SITE } from '../config';
---
<Notebook title="about me">
  <p>hi! i'm <strong>{SITE.name}</strong>.</p>
  <br />
  <p>i like building things that bridge software and the physical world —
     robot arms, ML models, microcontrollers, and the glue in between.</p>
  <br />
  <h2>what i'm into</h2>
  <ul>
    <li>robotics & simulation (MuJoCo, IK, manipulation)</li>
    <li>machine learning & vision-language models</li>
    <li>embedded systems & tinkering with hardware</li>
  </ul>
  <br />
  <h2>find me</h2>
  <ul>
    {SITE.links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
    <li>email: <a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
  </ul>
</Notebook>
