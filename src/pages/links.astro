---
import Notebook from '../layouts/Notebook.astro';
import { SITE } from '../config';
---
<Notebook title="links">
  <h2>me</h2>
  <ul>
    {SITE.links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
    <li>email: <a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
  </ul>
  <br />
  <h2>webring</h2>
  <p>once this site is live, i can join the
     <a href="https://webring.nekoweb.org/">nekoweb webring</a> or the
     <a href="https://webring.xxiivv.com/">xxiivv webring</a> — those
     <code>← →</code> arrows that hop between indie sites.</p>
  <br />
  <h2>sites i like</h2>
  <ul>
    <li><a href="https://sheep.nekoweb.org">sheep's site</a> (the inspiration ♥)</li>
  </ul>
</Notebook>
